{
    "python.defaultInterpreterPath": ".venv/Scripts/python.exe",
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "standard",
    "python.analysis.extraPaths": [
        "./src",
        "./safety",
        "./security",
        "./boundaries"
    ],
    "python.analysis.diagnosticSeverityOverrides": {},
    "python.analysis.autoImportCompletions": true,
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "tests"
    ],
    "files.eol": "\n",
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.autoSave": "onFocusChange",
    "files.exclude": {
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.rag_db": true,
        "**/.rag_logs": true,
        "**/.ruff_cache": true,
        "**/.storybook": true,
        "**/.test_eval_rag_db": true,
        "**/.test_rag_db": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/archive": true,
        "**/build": true,
        "**/coverage": true,
        "**/dist": true,
        "**/node_modules": true
    },
    "files.watcherExclude": {
        "**/.mypy_cache/**": true,
        "**/.pytest_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/archive/**": true,
        "**/build/**": true,
        "**/dist/**": true,
        "**/node_modules/**": true
    },
    "search.exclude": {
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.storybook": true,
        "**/.venv": true,
        "**/__pycache__": true,
        "**/archive": true,
        "**/build": true,
        "**/coverage": true,
        "**/dist": true,
        "**/frontend/dist": true,
        "**/node_modules": true,
        "**/uv.lock": true
    },
    "editor.formatOnSave": true,
    "[css]": {
        "editor.defaultFormatter": "codeium.windsurf",
        "editor.formatOnSave": true
    },
    "[javascript]": {
        "editor.defaultFormatter": "codeium.windsurf",
        "editor.formatOnSave": true
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "codeium.windsurf",
        "editor.formatOnSave": true
    },
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.defaultFormatter": "codeium.windsurf",
        "editor.formatOnSave": true,
        "editor.rulers": [
            120
        ]
    },
    "[typescript]": {
        "editor.defaultFormatter": "codeium.windsurf",
        "editor.formatOnSave": true,
        "editor.rulers": [
            120
        ]
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "codeium.windsurf",
        "editor.formatOnSave": true,
        "editor.rulers": [
            120
        ]
    },
    "ruff.enable": true,
    "ruff.fixAll": true,
    "ruff.importStrategy": "fromEnvironment",
    "ruff.organizeImports": true,
    "typescript.tsdk": "frontend/node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "tailwindCSS.experimental.classRegex": [
        [
            "cva\\(([^)]*)\\)",
            "[\"'`]([^\"'`]*).*?[\"'`]"
        ],
        [
            "cn\\(([^)]*)\\)",
            "[\"'`]([^\"'`]*).*?[\"'`]"
        ]
    ],
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.env.windows": {
        "COGNITIVE_HOME": "${workspaceFolder}/src/cognitive",
        "ENV": "development",
        "GRID_HOME": "${workspaceFolder}/src/grid",
        "PROJECT_ROOT": "${workspaceFolder}",
        "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/safety:${workspaceFolder}/security:${workspaceFolder}/boundaries",
        "PYTHON_VERSION": "3.13",
        "RESONANCE_HOME": "${workspaceFolder}/src/application/resonance"
    }
}
